generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrgType {
  buyer
  seller
  both
}

enum OrgRole {
  owner
  admin
  member
  viewer
}

enum ListingCondition {
  new
  used
  refurbished
}

enum ListingPriceType {
  fixed
  negotiable
  on_request
}

enum ListingStatus {
  draft
  active
  paused
  sold
  archived
}

enum InquiryStatus {
  sent
  replied
  negotiating
  closed
  lost
  spam
}

enum RfqStatus {
  draft
  active
  negotiating
  closed
  cancelled
}

enum RfqTargetType {
  broadcast
  manual
  system_match
}

enum RfqTargetStatus {
  invited
  viewed
  quoted
  declined
}

enum QuoteStatus {
  submitted
  revised
  accepted
  rejected
  withdrawn
}

enum ThreadType {
  inquiry
  rfq
  order
}

enum MessageType {
  text
  attachment
  system
}

enum VerificationType {
  gst
  iso
  factory_visit
  bank
  phone
  email
}

enum VerificationStatus {
  pending
  verified
  rejected
  expired
}

enum DocType {
  gst_certificate
  iso_certificate
  company_profile
  bank_cheque
  other
}

enum EventType {
  listing_view
  listing_click_whatsapp
  inquiry_created
  rfq_created
  rfq_viewed
  quote_submitted
  message_sent
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @unique
  phone     String?
  fullName  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships OrgMembership[]
  messages    Message[]
  events      Event[]
  receipts    ThreadReadReceipt[]

}

model Org {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgType   OrgType
  name      String
  gstin     String?  @unique
  website   String?
  phone     String?
  address1  String?
  address2  String?
  city      String?
  state     String?
  pincode   String?
  country   String?  @default("India")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members        OrgMembership[]
  listings       Listing[]
  buyerInquiries Inquiry[]       @relation("BuyerInquiries")
  rfqs           Rfq[]
  rfqTargets     RfqTarget[]
  quotes         Quote[]
  threadsBuyer   MessageThread[] @relation("BuyerThreads")
  threadsSeller  MessageThread[] @relation("SellerThreads")
  sentMessages   Message[]       @relation("SentMessages")
  verifications  OrgVerification[]
  documents      OrgDocument[]
  savedListings  SavedListing[]
  comparisonSets ComparisonSet[]
  events         Event[]

  @@index([orgType])
  @@index([state, city])
}

model OrgMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  userId    String   @db.Uuid
  role      OrgRole  @default(member)
  createdAt DateTime @default(now())

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

model Category {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId  String?   @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())

  parent     Category?           @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]          @relation("CategoryTree")
  attributes CategoryAttribute[]
  listings   Listing[]
  rfqs       Rfq[]

  @@index([parentId])
}

enum AttributeDataType {
  text
  number
  boolean
  select
  multi_select
}

model CategoryAttribute {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId   String            @db.Uuid
  key          String
  label        String
  dataType     AttributeDataType
  unit         String?
  options      Json?
  isFilterable Boolean           @default(false)
  isRequired   Boolean           @default(false)

  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  listingSpecs ListingSpec[]
  rfqReqs      RfqRequirement[]

  @@unique([categoryId, key])
  @@index([categoryId])
}

model Listing {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerOrgId         String           @db.Uuid
  categoryId          String           @db.Uuid
  title               String
  description         String?
  condition           ListingCondition
  priceAmount         Decimal?
  priceCurrency       String           @default("INR")
  priceType           ListingPriceType @default(on_request)
  quantity            Int              @default(1)
  locationCity        String?
  locationState       String?
  locationPincode     String?
  leadTimeDays        Int?
  warrantyMonths      Int?
  gstInvoiceAvailable Boolean          @default(false)
  status              ListingStatus    @default(draft)
  publishedAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  sellerOrg    Org              @relation(fields: [sellerOrgId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  specs        ListingSpec[]
  media        ListingMedia[]
  inquiries    Inquiry[]
  savedBy      SavedListing[]
  compareItems ComparisonSetItem[]
  events       Event[]

  @@index([sellerOrgId, status])
  @@index([categoryId, status])
  @@index([locationState, locationCity])
}

model ListingSpec {
  listingId   String  @db.Uuid
  attributeId String  @db.Uuid
  valueText   String?
  valueNum    Decimal?
  valueBool   Boolean?
  valueJson   Json?

  listing   Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attribute CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([listingId, attributeId])
  @@index([attributeId])
}

model ListingMedia {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId String   @db.Uuid
  mediaType String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, sortOrder])
}

model Inquiry {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerOrgId         String        @db.Uuid
  listingId          String        @db.Uuid
  subject            String?
  message            String
  quantity           Int?
  targetBudgetAmount Decimal?
  status             InquiryStatus @default(sent)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  buyerOrg Org     @relation("BuyerInquiries", fields: [buyerOrgId], references: [id], onDelete: Cascade)
  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  thread   MessageThread[]

  @@index([buyerOrgId, createdAt])
  @@index([listingId, createdAt])
}

model Rfq {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerOrgId      String    @db.Uuid
  categoryId      String    @db.Uuid
  title           String
  description     String?
  budgetMin       Decimal?
  budgetMax       Decimal?
  currency        String    @default("INR")
  deliveryCity    String?
  deliveryState   String?
  deliveryPincode String?
  requiredByDate  DateTime?
  status          RfqStatus @default(draft)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  buyerOrg     Org              @relation(fields: [buyerOrgId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  requirements RfqRequirement[]
  targets      RfqTarget[]
  quotes       Quote[]
  threads      MessageThread[]
  events       Event[]

  @@index([buyerOrgId, createdAt])
  @@index([status, createdAt])
}

model RfqRequirement {
  rfqId       String  @db.Uuid
  attributeId String  @db.Uuid
  valueText   String?
  valueNum    Decimal?
  valueBool   Boolean?
  valueJson   Json?

  rfq       Rfq              @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  attribute CategoryAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([rfqId, attributeId])
  @@index([attributeId])
}

model RfqTarget {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rfqId       String          @db.Uuid
  sellerOrgId String          @db.Uuid
  targetType  RfqTargetType   @default(broadcast)
  status      RfqTargetStatus @default(invited)
  invitedAt   DateTime        @default(now())
  viewedAt    DateTime?

  rfq       Rfq @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerOrg Org @relation(fields: [sellerOrgId], references: [id], onDelete: Cascade)

  @@unique([rfqId, sellerOrgId])
  @@index([sellerOrgId, invitedAt])
  @@index([rfqId, status])
}

model Quote {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rfqId          String      @db.Uuid
  sellerOrgId    String      @db.Uuid
  amount         Decimal
  currency       String      @default("INR")
  leadTimeDays   Int?
  warrantyMonths Int?
  notes          String?
  status         QuoteStatus @default(submitted)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  rfq       Rfq           @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  sellerOrg Org           @relation(fields: [sellerOrgId], references: [id], onDelete: Cascade)
  lineItems QuoteLineItem[]

  @@unique([rfqId, sellerOrgId])
  @@index([rfqId, amount])
}

model QuoteLineItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId   String  @db.Uuid
  label     String
  amount    Decimal
  sortOrder Int     @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, sortOrder])
}

model MessageThread {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadType    ThreadType
  inquiryId     String?    @db.Uuid
  rfqId         String?    @db.Uuid
  buyerOrgId    String     @db.Uuid
  sellerOrgId   String     @db.Uuid
  lastMessageAt DateTime   @default(now())
  createdAt     DateTime   @default(now())

  buyerOrg  Org      @relation("BuyerThreads", fields: [buyerOrgId], references: [id], onDelete: Cascade)
  sellerOrg Org      @relation("SellerThreads", fields: [sellerOrgId], references: [id], onDelete: Cascade)
  inquiry   Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  rfq       Rfq?     @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  messages  Message[]
  receipts  ThreadReadReceipt[]

  @@index([buyerOrgId, lastMessageAt])
  @@index([sellerOrgId, lastMessageAt])
}

model Message {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId     String      @db.Uuid
  senderUserId String      @db.Uuid
  senderOrgId  String      @db.Uuid
  messageType  MessageType @default(text)
  body         String?
  createdAt    DateTime    @default(now())

  thread      MessageThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User               @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  senderOrg   Org                @relation("SentMessages", fields: [senderOrgId], references: [id], onDelete: Cascade)
  attachments MessageAttachment[]

  @@index([threadId, createdAt])
  @@index([senderOrgId, createdAt])
}

model MessageAttachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId     String   @db.Uuid
  url           String
  fileName      String?
  mimeType      String?
  fileSizeBytes Int?
  createdAt     DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ThreadReadReceipt {
  threadId   String   @db.Uuid
  userId     String   @db.Uuid
  lastReadAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([threadId, userId])
}

model SavedListing {
  buyerOrgId String   @db.Uuid
  listingId  String   @db.Uuid
  createdAt  DateTime @default(now())

  buyerOrg Org     @relation(fields: [buyerOrgId], references: [id], onDelete: Cascade)
  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([buyerOrgId, listingId])
  @@index([buyerOrgId, createdAt])
}

model ComparisonSet {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerOrgId String   @db.Uuid
  name       String
  createdAt  DateTime @default(now())

  buyerOrg Org                 @relation(fields: [buyerOrgId], references: [id], onDelete: Cascade)
  items    ComparisonSetItem[]

  @@index([buyerOrgId, createdAt])
}

model ComparisonSetItem {
  comparisonSetId String   @db.Uuid
  listingId       String   @db.Uuid
  createdAt       DateTime @default(now())

  set     ComparisonSet @relation(fields: [comparisonSetId], references: [id], onDelete: Cascade)
  listing Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([comparisonSetId, listingId])
}

model OrgVerification {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId            String             @db.Uuid
  verificationType VerificationType
  status           VerificationStatus @default(pending)
  referenceId      String?
  verifiedAt       DateTime?
  expiresAt        DateTime?
  notes            String?
  createdAt        DateTime           @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([verificationType, status])
}

model OrgDocument {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @db.Uuid
  docType   DocType
  url       String
  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, docType])
}

model Event {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType EventType
  orgId     String?   @db.Uuid
  userId    String?   @db.Uuid
  listingId String?   @db.Uuid
  rfqId     String?   @db.Uuid
  meta      Json?
  createdAt DateTime  @default(now())

  org     Org?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  rfq     Rfq?     @relation(fields: [rfqId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([orgId, createdAt])
  @@index([listingId, createdAt])
  @@index([rfqId, createdAt])
}
